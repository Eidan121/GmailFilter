# Copy to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth client (one-time operator setup — create an OAuth 2.0 "Web
# application" client in Google Cloud Console with redirect URI
# http://localhost:8000/api/accounts/callback). End users connecting their
# Gmail account never see these values; they only see Google's consent screen.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Optional: fixed key for encrypting stored Gmail tokens at rest (Fernet key,
# e.g. `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`).
# If unset, a key is generated on first run and stored at ~/.gmail_filter_app/token.key
# TOKEN_ENCRYPTION_KEY=

# Postgres (used by the `db` service in docker-compose and by the backend's
# DATABASE_URL). Defaults below match docker-compose's defaults — change them
# together if you change one.
# POSTGRES_USER=gmailfilter
# POSTGRES_PASSWORD=gmailfilter
# POSTGRES_DB=gmailfilter

# Only needed when running the backend outside Docker against a Postgres
# exposed on localhost (docker-compose sets this itself for in-container use):
# DATABASE_URL=postgresql+psycopg://gmailfilter:gmailfilter@localhost:5432/gmailfilter

# Optional overrides
# API_HOST=0.0.0.0
# API_PORT=8000
# Public base URL the backend is reachable at — used to build the OAuth
# redirect URI. Must match a redirect URI registered in Google Cloud Console.
# Defaults to http://localhost:8000 for local dev; override in production,
# e.g. http://<vm-host>:8000
# OAUTH_REDIRECT_BASE_URL=http://localhost:8000
# FRONTEND_ORIGIN=http://localhost:5173
# FLOOD_THRESHOLD=20
# SCAN_INTERVAL_HOURS=6
